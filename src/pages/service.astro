---
import Layout from '../layouts/Layout.astro';
import * as serviceData from '../content/service.md';
const { frontmatter } = serviceData;
---

<Layout
 title={`${frontmatter.title} | 一樂 迦哩無 - 公式サイト`}
 description={frontmatter.summary || "集客やホームページ制作、SNS・YouTube運用にお悩みのライトワーカー様へ。Webサイト制作からデザイン、動画撮影・編集、ライティングまで、あなたの活動をトータルでサポートする「お助け最強パック」をご紹介。ご状況や予算に応じた最適なメニューをご提案します。"}>
  <!-- メインコンテンツ -->
  <main class="detailed-container">
    <section class="card-panel">
      <div class="program-header-block">
        <p class="catchphrase">{frontmatter.catchphrase}</p>
        <h2>{frontmatter.title}</h2>
      </div>
      
      <div class="card-content detailed-body">

        {frontmatter.image && (
          <div class="toppage-image-container">
            <img src={frontmatter.image} alt="メインイメージ" class="toppage-main-image" />
          </div>
        )}

        <div class="summary-message">
          <p>{frontmatter.summary}</p>
        </div>

        <hr class="divider" />
        <!-- Markdownの本文を自動展開 -->
        <div class="markdown-content">
          <serviceData.Content />
        </div>
        
        <div class="back-home-container">
            <a href="/" class="back-home-link">トップページへ戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- ページ全体のメインスタイル -->
<style>
  /* コンテナ */
  .detailed-container {
    flex: 1;
    max-width: 950px;
    margin: 140px auto 60px auto;
    padding: 0 1.5rem;
    width: 100%;
  }
  
  .card-panel {
    background: rgba(13, 11, 24, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08); 
    border-radius: 16px;
    padding: 3rem; 
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }
  
  /* テキスト・見出し装飾 */
  .program-header-block h2 { 
    font-size: 2.2rem; 
    margin-top: 0.5rem; 
    margin-bottom: 2rem; 
    color: #fff;
    font-weight: bold;
    letter-spacing: 0.05em;
  }
  .catchphrase {
    color: #ffb7ff; font-size: 0.95rem; font-weight: bold; margin: 0; letter-spacing: 0.15em;
    white-space: pre-line;
  }
  .summary-message p { 
    font-size: 1.1rem; 
    line-height: 1.8; 
    color: #dbd7e0;
    white-space: pre-line;
  }
  
  .divider {
    border: 0; height: 1px;
    background: linear-gradient(to right, rgba(255,255,255,0), rgba(255,255,255,0.15), rgba(255,255,255,0));
    margin: 3rem 0;
  }

  /* 戻るリンク */
  .back-home-container { text-align: center; margin-top: 4rem; }
  .back-home-link { color: #aaa; text-decoration: none; font-size: 0.95rem; transition: color 0.3s; }
  .back-home-link:hover { color: #ffb7ff; }

  @media (max-width: 768px) {
    .detailed-container { margin-top: 120px; }
    .card-panel { padding: 1.5rem; }
    .program-header-block h2 { font-size: 1.7rem; }
  }

  /* ===================================================
      📚 [干渉排除＋再構築] マークダウン専用の新しいリストデザイン
     =================================================== */

  .markdown-content :global(h3) {
    font-size: 1.35rem !important;
    color: #fff !important;
    border-left: 4px solid #ffb7ff !important;
    padding-left: 14px !important;
    margin: 2rem 0 !important;
    font-weight: bold !important;
  }

  /* 
    干渉している不要なグローバルスタイルを初期化。
    ただし、中項目や小項目の「角丸四角」としてのコンテナ表現は、下部で美しく再定義します。
  */
  .markdown-content :global(ul),
  .markdown-content :global(ul li),
  .markdown-content :global(ul li::before),
  .markdown-content :global(ul li::after) {
    box-shadow: none !important;
    width: auto !important;
    height: auto !important;
    content: none !important;
    position: static !important;
    transform: none !important;
  }

  /* 1. 外側のカード一覧（2列のグリッド配置） */
  .markdown-content :global(ul:first-of-type) {
    display: grid !important;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)) !important;
    gap: 1.5rem !important;
    margin: 2rem 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  /* 2. 大項目「カード」（1〜4の大枠。ここにだけ個別の背景色を割り当てます） */
  .markdown-content :global(ul:first-of-type > li) {
    display: block !important;
    border-radius: 12px !important;
    padding: 1.8rem 1.8rem 1.5rem 1.8rem !important;
    position: relative !important;
    overflow: hidden !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25) !important;
    background: none !important;
    border: none !important;
  }

  /* 🎨 各カードごとの背景色を微調整 */
  /* カード1：ブルー（Web制作 & 運用） */
  .markdown-content :global(ul:first-of-type > li:nth-of-type(1)) {
    background: rgba(0, 114, 255, 0.08) !important;
    border: 1px solid rgba(0, 198, 255, 0.2) !important;
  }
  /* カード2：マゼンタ（デザイン & ビジュアル） */
  .markdown-content :global(ul:first-of-type > li:nth-of-type(2)) {
    background: rgba(255, 94, 98, 0.08) !important;
    border: 1px solid rgba(255, 153, 102, 0.2) !important;
  }
  /* カード3：パープル（動画 & 写真） */
  .markdown-content :global(ul:first-of-type > li:nth-of-type(3)) {
    background: rgba(127, 0, 255, 0.08) !important;
    border: 1px solid rgba(225, 0, 255, 0.2) !important;
  }
  /* カード4：グリーン（ライティング & 教材） */
  .markdown-content :global(ul:first-of-type > li:nth-of-type(4)) {
    background: rgba(17, 153, 142, 0.08) !important;
    border: 1px solid rgba(56, 239, 125, 0.2) !important;
  }

  /* ===================================================
      ⚡ ① 大タイトルテキストの折り返し防止・文字サイズ調整
     =================================================== */
  .markdown-content :global(ul:first-of-type > li) {
    font-size: 1.2rem !important; 
    font-weight: 850 !important;   
    letter-spacing: 0.05em !important;
    line-height: 1.3 !important;
  }

  /* 各大タイトル個別の光彩（ネオンカラー）設定 */
  .markdown-content :global(ul:first-of-type > li:nth-of-type(1)) {
    color: #a3e2ff !important;
    text-shadow: 0 0 10px rgba(0, 198, 255, 0.6) !important;
  }
  .markdown-content :global(ul:first-of-type > li:nth-of-type(2)) {
    color: #ffb7ff !important;
    text-shadow: 0 0 10px rgba(255, 94, 98, 0.6) !important;
  }
  .markdown-content :global(ul:first-of-type > li:nth-of-type(3)) {
    color: #e100ff !important;
    text-shadow: 0 0 10px rgba(127, 0, 255, 0.7) !important;
  }
  .markdown-content :global(ul:first-of-type > li:nth-of-type(4)) {
    color: #38ef7d !important;
    text-shadow: 0 0 10px rgba(17, 153, 142, 0.7) !important;
  }


  /* ===================================================
      💤 ② 下層の箇条書き（中・小項目）の余白・角丸ボックス再構築
     =================================================== */

  /* 中項目のリスト全体コンテナ */
  .markdown-content :global(ul:first-of-type > li > ul) {
    display: block !important;
    margin-top: 1.2rem !important;
    padding: 0 !important;
    border-top: 1px solid rgba(255, 255, 255, 0.12) !important; 
    padding-top: 1.2rem !important;
    background: none !important;
    border-left: none !important;
    border-right: none !important;
    border-bottom: none !important;
  }

  /* 
    中項目（「Webサイト制作」など）を包む枠
    ★ここで、美しく調和する角丸四角と程よい内側余白（パディング）を割り当てます
  */
  .markdown-content :global(ul:first-of-type > li > ul > li) {
    display: block !important;
    /* 控えめでスタイリッシュな角丸枠線を設定 */
    background: rgba(255, 255, 255, 0.03) !important; 
    border: 1px solid rgba(255, 255, 255, 0.08) !important; 
    border-radius: 8px !important; /* 美しい角丸 */
    
    /* ギチギチにならず、広がりすぎない上品な余白を設計 */
    padding: 0.9rem 1.1rem !important; 
    margin-top: 0 !important;
    margin-bottom: 1rem !important; /* 各コンテナ同士の適度な縦すき間 */
    
    font-size: 1.0rem !important;
    color: #dbd7e0 !important;   
    font-weight: normal !important; 
    text-shadow: none !important; 
    position: relative !important;
  }
  
  /* 最後の要素の余白を少し調整して、カード下部に合わせる */
  .markdown-content :global(ul:first-of-type > li > ul > li:last-of-type) {
    margin-bottom: 0 !important;
  }

  /* 強調タグのリセット */
  .markdown-content :global(ul:first-of-type > li > ul > li strong) {
    color: #dbd7e0 !important;
    font-weight: normal !important;
    text-shadow: none !important;
    background: none !important;
    border: none !important;
  }

  /* 中項目のポインター：ドットを少し右にずらして余白と調和させます */
  .markdown-content :global(ul:first-of-type > li > ul > li::before) {
    content: '•' !important;
    position: absolute !important;
    left: 12px !important;
    top: 0.9rem !important; /* テキストの1行目の高さに合わせる */
    color: rgba(255, 255, 255, 0.4) !important; 
    font-size: 1rem !important;
    font-weight: normal !important;
  }
  
  /* 中項目のテキスト自体も、ポインターと被らないように少し右へ */
  .markdown-content :global(ul:first-of-type > li > ul > li) {
    padding-left: 26px !important; 
  }

  /* 小項目（具体的な対応業務などを包むul） */
  .markdown-content :global(ul:first-of-type > li > ul > li > ul) {
    display: block !important;
    margin-top: 0.6rem !important; /* コンテナ内の中タイトルと小タイトル間の程よいすき間 */
    margin-bottom: 0 !important;
    padding-left: 0px !important;
    background: none !important;
    border: none !important;
  }

  /* 小項目の中身
     中項目の角丸ボックスの中にスッキリ綺麗に並ぶよう、個別の背景などは持たせません
  */
  .markdown-content :global(ul:first-of-type > li > ul > li > ul > li) {
    display: block !important;
    background: none !important; 
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    
    padding-left: 16px !important;
    padding-top: 2px !important;  
    padding-bottom: 2px !important;
    margin: 0.4rem 0 !important;
    
    font-size: 0.88rem !important;
    color: #b0abc4 !important; /* 少し明るくして視認性を確保 */
    font-weight: normal !important;
    position: relative !important;
  }

  /* 小項目のポインター：控えめな極小中空丸「◦」 */
  .markdown-content :global(ul:first-of-type > li > ul > li > ul > li::before) {
    content: '◦' !important;
    position: absolute !important;
    left: 2px !important;
    top: 2px !important;
    color: rgba(255, 255, 255, 0.3) !important; 
    font-size: 0.85rem !important;
  }

  @media (max-width: 768px) {
    .markdown-content :global(ul:first-of-type) {
      grid-template-columns: 1fr !important;
    }
    .markdown-content :global(ul:first-of-type > li) {
      font-size: 1.1rem !important; 
      padding: 1.5rem 1.5rem 1.2rem 1.5rem !important;
    }
    .markdown-content :global(ul:first-of-type > li > ul > li) {
      padding: 0.8rem 1rem 0.8rem 22px !important;
    }
    .markdown-content :global(ul:first-of-type > li > ul > li::before) {
      left: 10px !important;
      top: 0.8rem !important;
    }
  }
</style>

<!-- グローバル用の独立スタイル -->
<style is:global>
  .toppage-image-container {
    width: 100%;
    margin: 0 auto 2rem auto;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(255, 183, 255, 0.2);
    border: 1px solid rgba(255, 183, 255, 0.3);
  }
  .toppage-main-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
</style>