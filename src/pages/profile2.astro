---
import Layout from '../layouts/Layout.astro';

// ★テキストファイルを読み込む
import * as profile2Data from '../content/profile2.md';
const { frontmatter } = profile2Data;
---

<Layout title="一樂 迦哩無について - 詳細プロフィール | 一樂 迦哩無 - 公式サイト">
  <!-- メインコンテンツ（中央配置の1カラムコンテナ） -->
  <main class="detailed-container">
    <section class="card-panel">
      <div class="profile-header-block">
        <p class="catchphrase">{frontmatter.catchphrase}</p>
        <h2>{frontmatter.title}</h2>
      </div>
      
      <div class="card-content detailed-story">
        {frontmatter.image && (
          <div class="toppage-image-container">
            <img src={frontmatter.image} alt={frontmatter.title} class="toppage-main-image" />
          </div>
        )}

        <div class="intro-message">
          <p class="greeting">{frontmatter.greeting}</p>
          <blockquote>
            {frontmatter.quote}
          </blockquote>
        </div>
        

        <!-- Markdownの本文（プロフィールストーリーやスキルなど）を自動展開 -->
        <profile2Data.Content />

        <div class="back-home-container">
            <a href="/" class="back-home-link">トップページへ戻る</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<!-- ② ページ全体のメインスタイル（profile2 個別用） -->
<style>
  /* メインコンテンツコンテナ */
  .detailed-container {
    flex: 1;
    max-width: 900px; 
    margin: 140px auto 60px auto; 
    padding: 0 1.5rem;
    width: 100%;
  }
  
  /* カードパネル設定 */
  .card-panel {
    background: rgba(13, 11, 24, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px;
    padding: 2.5rem; backdrop-filter: blur(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }
  
  /* テキスト装飾 */
  .profile-header-block h2 { font-size: 2rem; margin-top: 0.2rem; margin-bottom: 2rem; }
  .catchphrase {
    color: #ffb7ff; font-size: 0.95rem; font-weight: bold; margin: 0; letter-spacing: 0.1em;
    white-space: pre-line;
  }

  .detailed-story p { 
    line-height: 1.85; margin-bottom: 1.4rem; color: #dbd7e0; letter-spacing: 0.03em;
  }
  .intro-message .greeting { font-size: 1.15rem; font-weight: bold; color: #fff; }
  .intro-message blockquote {
    margin: 1.5rem 0; padding-left: 1.2rem; border-left: 3px solid #ffb7ff;
    font-style: italic; color: #fff; font-size: 1.1rem;
    white-space: pre-line;
  }

  /* ===================================================
     📚 Kindle書籍 紹介カード（2冊用コンテナ）
     =================================================== */
  .books-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 3.5rem 0;
  }

  .book-promo-card {
    display: flex !important;
    align-items: center !important;
    gap: 2.5rem !important;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 183, 255, 0.04) 100%) !important;
    border: 1px solid rgba(255, 183, 255, 0.15) !important;
    border-radius: 16px !important;
    padding: 2.5rem !important;
    box-shadow: 0 8px 32px rgba(13, 11, 24, 0.5), inset 0 0 15px rgba(255, 183, 255, 0.05) !important;
    position: relative !important;
    overflow: hidden !important;
  }

  /* 書籍画像エリア */
  .book-img-area {
    flex: 0 0 160px !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
  }
  .book-cover-img {
    width: 100% !important;
    height: auto !important;
    border-radius: 6px !important;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.6), 0 0 10px rgba(255, 183, 255, 0.1) !important;
    transition: transform 0.3s ease !important;
  }
  .book-promo-card:hover .book-cover-img {
    transform: translateY(-5px) scale(1.02) !important;
  }

  /* 書籍情報エリア */
  .book-info-area {
    flex: 1 !important;
    text-align: left !important;
  }

  /* 好評発売中バッジ */
  .book-promo-badge {
    display: inline-block !important;
    background: linear-gradient(90deg, #ff5e62, #ff9966) !important;
    color: #fff !important;
    font-size: 0.8rem !important;
    font-weight: bold !important;
    letter-spacing: 0.1em !important;
    padding: 0.3rem 1.2rem !important;
    border-radius: 20px !important;
    margin-bottom: 1rem !important;
    box-shadow: 0 0 10px rgba(255, 94, 98, 0.3) !important;
  }

  /* 2冊目のバッジ色を「源（source）」をイメージした紫・青系に微変化させ知的な印象に */
  .source-badge {
    background: linear-gradient(90deg, #8a2be2, #4a00e0) !important;
    box-shadow: 0 0 10px rgba(138, 43, 226, 0.3) !important;
  }

  /* 書籍タイトル */
  .book-promo-title {
    font-size: 1.35rem !important;
    color: #fff !important;
    text-shadow: 0 0 10px rgba(255, 183, 255, 0.3) !important;
    margin: 0 0 0.8rem 0 !important;
    font-weight: bold !important;
    letter-spacing: 0.05em !important;
  }

  /* 書籍説明文 */
  .book-promo-description {
    font-size: 0.95rem !important;
    color: #dbd7e0 !important;
    line-height: 1.7 !important;
    margin: 0 0 1.5rem 0 !important;
  }

  .book-promo-card .action-buttons-container {
    margin: 0 !important;
    justify-content: flex-start !important;
  }
  
  /* 戻るリンク */
  .back-home-container { text-align: center; margin-top: 4rem; }
  .back-home-link { color: #aaa; text-decoration: none; font-size: 0.95rem; transition: color 0.3s; }
  .back-home-link:hover { color: #ffb7ff; }

  /* レスポンシブ対応 */
  @media (max-width: 768px) {
    .detailed-container { margin-top: 120px; }
    .card-panel { padding: 1.5rem; }
    .profile-header-block h2 { font-size: 1.6rem; }

    /* スマホ時は縦並びにする */
    .book-promo-card {
      flex-direction: column !important;
      gap: 1.5rem !important;
      padding: 2rem 1.5rem !important;
    }
    .book-img-area {
      flex: 0 0 150px !important;
      max-width: 150px !important;
    }
    .book-info-area {
      text-align: center !important;
      width: 100% !important;
    }
    .book-promo-card .action-buttons-container {
      justify-content: center !important;
    }
  }
</style>

<!-- ✨ Markdownの中身を確実に装飾するためのグローバル指定 -->
<style is:global>
  /* Markdownの「###」を左線付きのネオンラインに */
  .card-panel h3 {
    font-size: 1.35rem !important;
    color: #ffb7ff !important;
    text-shadow: 0 0 10px rgba(255, 183, 255, 0.4) !important;
    border-left: 3px solid #ffb7ff !important;
    padding-left: 0.8rem !important;
    margin-top: 3.5rem !important;
    margin-bottom: 2rem !important;
    letter-spacing: 0.08em !important;
    background: none !important;
  }
  
  /* リスト全体に薄いオーラのような背景グラデーションを敷く */
  .card-panel h4 + ul {
    list-style: none !important;
    padding-left: 0 !important;
    margin: 0.8rem 0 2rem 0 !important;
    background: linear-gradient(to right, rgba(163, 226, 255, 0.03), transparent) !important;
    padding: 1rem 1.2rem !important;
    border-radius: 6px !important;
  }
  
  /* 各リスト項目の設定 */
  .card-panel ul li {
    position: relative !important;
    padding-left: 1.4rem !important;
    margin-bottom: 0.6rem !important;
    color: #dbd7e0 !important;
    font-size: 0.95rem !important;
    background: none !important;
    border: none !important;
  }
  
  /* 行頭の丸ドットを、光る星屑（✦）に */
  .card-panel ul li::before {
    content: "✦" !important;
    color: #a3e2ff !important;
    position: absolute !important;
    left: 0 !important;
    top: -1px !important;
    font-size: 0.9rem !important;
    line-height: 1.4 !important;
    background: none !important;
    width: auto !important;
    height: auto !important;
    text-shadow: 0 0 4px rgba(163, 226, 255, 0.6) !important;
  }

  /* 小見出し（####）のカラーを水色に統一 */
  .card-panel h4 {
    margin-top: 2rem !important;
    margin-bottom: 0.6rem !important;
    font-size: 1.1rem !important;
    color: #a3e2ff !important;
    letter-spacing: 0.05em !important;
  }

  /* 普通の文章テキスト（p）の余白とバランス調整 */
  .card-panel h4 + p {
    line-height: 1.85 !important;
    color: #dbd7e0 !important;
    margin-bottom: 2rem !important;
    letter-spacing: 0.03em !important;
    padding-left: 1.2rem !important;
  }

  /* Markdown内の区切り線（---）の装飾 */
  .card-panel hr {
    border: 0 !important;
    height: 1px !important;
    background: linear-gradient(to right, rgba(255,255,255,0), rgba(255, 183, 255, 0.4), rgba(255,255,255,0)) !important;
    margin: 3.5rem 0 !important;
  }

  /* ===================================================
     ⚡ アクションボタンのグローバル装飾
     =================================================== */
  .action-buttons-container {
    display: flex !important;
    justify-content: center !important;
    gap: 1.5rem !important;
    margin: 3.5rem 0 !important;
    width: 100% !important;
    flex-wrap: wrap !important;
  }

  .btn-action {
    flex: 1 !important;
    max-width: 320px !important;
    min-width: 260px !important;
    height: 56px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    font-size: 1.05rem !important;
    font-weight: bold !important;
    letter-spacing: 0.05em !important;
    border-radius: 30px !important;
    position: relative !important;
    transition: all 0.4s ease !important;
    z-index: 1 !important;
    overflow: hidden !important;
    border: none !important;
  }

  .btn-action span {
    position: relative !important;
    z-index: 2 !important;
  }

  /* Amazonボタン：オレンジ〜ピンクグラデーション */
  .btn-apply {
    background: linear-gradient(135deg, #ff5e62, #ff9966) !important;
    color: #fff !important;
    box-shadow: 0 4px 15px rgba(255, 94, 98, 0.4) !important;
  }

  .btn-apply::before {
    content: '' !important;
    position: absolute !important;
    top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important;
    background: linear-gradient(135deg, #ff9966, #ff5e62) !important;
    opacity: 0 !important;
    z-index: 1 !important;
    transition: opacity 0.4s ease !important;
  }

  .btn-apply:hover {
    transform: translateY(-3px) !important;
    box-shadow: 0 8px 25px rgba(255, 94, 98, 0.6), 0 0 15px rgba(255, 153, 102, 0.4) !important;
  }
  
  .btn-apply:hover::before {
    opacity: 1 !important;
  }

  /* 訪問済みリンクのカラー対策 */
  .btn-apply:visited,
  .btn-apply:visited span {
    color: #fff !important;
  }

  @media (max-width: 600px) {
    .action-buttons-container {
      flex-direction: column !important;
      align-items: center !important;
      gap: 1.2rem !important;
    }
    .btn-action {
      width: 100% !important;
      max-width: 100% !important;
    }
  }
</style>

<!-- ③ メイン画像用コンテナスタイル -->
<style is:global>
  .toppage-image-container {
    width: 50%; /* 半分の大きさに指定 */
    margin: 0 auto 2rem auto; /* 中央配置 */
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(255, 183, 255, 0.2);
    border: 1px solid rgba(255, 183, 255, 0.3);
  }
  .toppage-main-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  /* スマホ等で小さくなりすぎないための調整 */
  @media (max-width: 768px) {
    .toppage-image-container {
      width: 80%;
    }
  }
</style>

<!-- 新規ウィンドウ用の安心スクリプト -->
<script is:inline>
  function setupFormButtons() {
    const container = document.querySelector('.action-buttons-container');
    if (!container) return;

    const links = document.querySelectorAll('.book-promo-card .action-buttons-container a');
    links.forEach(link => {
      link.setAttribute('target', '_blank');
      link.setAttribute('rel', 'noopener noreferrer');
      
      link.onclick = function(e) {
        e.preventDefault();
        e.stopPropagation();
        const href = this.getAttribute('href');
        if (href) {
          window.open(href, '_blank', 'noopener,noreferrer');
        }
        return false;
      };
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupFormButtons);
  } else {
    setupFormButtons();
  }

  document.addEventListener('astro:page-load', setupFormButtons);
  document.addEventListener('astro:after-swap', setupFormButtons);
</script>