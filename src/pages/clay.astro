---
import bgGalaxy from '../assets/bg-galaxy.avif';
import logo from '../assets/logo.avif';

// ★新しく作ったクレイワーク用のMarkdownを読み込む
import * as clayData from '../content/clay.md';
const { frontmatter } = clayData;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title} | 一樂 迦哩無 - 公式サイト</title>
  </head>
  <body>
    <!-- 背景画像 -->
    <div class="bg-layer"></div>

    <!-- ヘッダー -->
    <header class="site-header">
      <div class="logo-area">
        <a href="/"><img src={logo.src} alt="一樂 迦哩無" class="site-logo-img" /></a>
      </div>
      <nav class="nav-menu">
        <ul>
          <li><a href="/#profile">プロフィール</a></li>
          <li><a href="/#activities">活動内容</a></li>
          <li><a href="/#clay">クレイワーク・プログラム</a></li>
          <li><a href="/#service">ライトワーカー様向けサービス</a></li>
          <li><a href="/#contact">お申し込み・お問い合わせ</a></li>
        </ul>
      </nav>
    </header>

    <!-- メインコンテンツ -->
    <main class="detailed-container">
      <section class="card-panel">
        <div class="program-header-block">
          <p class="catchphrase">{frontmatter.catchphrase}</p>
          <h2>{frontmatter.title}</h2>
        </div>
        
        <div class="card-content detailed-body">
        <img src={frontmatter.image} alt="クレイワーク・メインイメージ" class="program-main-img" />
          <div class="summary-message">
            <p>{frontmatter.summary}</p>
          </div>

          <hr class="divider" />
          <!-- Markdownの本文（特徴、おすすめの人、内容など）を自動展開 -->
          <div class="markdown-content">
            <clayData.Content />
          </div>
          
          <div class="back-home-container">
              <a href="/" class="back-home-link">トップページへ戻る</a>
          </div>
        </div>
      </section>
    </main>

    <!-- フッター -->
    <footer class="site-footer">
      <div class="footer-content">
        <p class="copyright">&copy; 2026 一樂 迦哩無 All Rights Reserved.</p>
      </div>
    </footer>
  </body>
</html>

<!-- スタイル設定 -->
<!-- ① 背景専用のスタイル（影響をここに閉じ込める） -->
<style define:vars={{ bgUrl: `url(${bgGalaxy.src})` }}>
  .bg-layer {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background-image: var(--bgUrl); background-size: cover; background-position: center;
    z-index: -2; opacity: 0.7;
    animation: bgMovement 25s ease-in-out infinite alternate;
  }
  @keyframes bgMovement {
    0% { transform: scale(1) rotate(0deg); }
    100% { transform: scale(1.08) rotate(1deg); }
  }
</style>

<!-- ② ページ全体のメインスタイル（持ち物2列＆料金カード完全版） -->
<style>
  * { box-sizing: border-box; }
  body { 
    margin: 0; padding: 0;
    background: #0d0b18; color: #f0ecf4; 
    font-family: 'Helvetica Neue', Arial, sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
    display: flex; flex-direction: column;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ヘッダー */
  .site-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.5rem 3rem; height: 100px;
    background: rgba(13, 11, 24, 0.6); backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: fixed; top: 0; width: 100%; z-index: 100;
  }
  .site-logo-img { max-height: 80px; width: auto; object-fit: contain; }
  .nav-menu ul { display: flex; list-style: none; gap: 2rem; margin: 0; padding: 0; }
  .nav-menu a { color: #fff; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.3s; }
  .nav-menu a:hover { color: #ffb7ff; text-shadow: 0 0 8px #ffb7ff; }

  /* コンテナ */
  .detailed-container {
    flex: 1;
    max-width: 900px;
    margin: 140px auto 60px auto;
    padding: 0 1.5rem;
    width: 100%;
  }
  
  .card-panel {
    background: rgba(13, 11, 24, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px;
    padding: 2.5rem; backdrop-filter: blur(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    overflow: hidden;
  }
  
  /* テキスト・見出し装飾 */
  .program-header-block h2 { font-size: 2rem; margin-top: 0.2rem; margin-bottom: 2rem; }
  .catchphrase {
    color: #ffb7ff; font-size: 0.95rem; font-weight: bold; margin: 0; letter-spacing: 0.1em;
    white-space: pre-line;
  }
  .summary-message p { font-size: 1.1rem; line-height: 1.8; color: #fff;
    white-space: pre-line;
  }
  
  .divider {
    border: 0; height: 1px;
    background: linear-gradient(to right, rgba(255,255,255,0), rgba(255,255,255,0.15), rgba(255,255,255,0));
    margin: 2.5rem 0;
  }

  /* 戻るリンク */
  .back-home-container { text-align: center; margin-top: 4rem; }
  .back-home-link { color: #aaa; text-decoration: none; font-size: 0.95rem; transition: color 0.3s; }
  .back-home-link:hover { color: #ffb7ff; }

  /* フッター */
  .site-footer {
    display: block !important; position: relative; z-index: 9999 !important; width: 100vw;
    margin-left: calc(-50vw + 50%); background: #0d0b18 !important;
    border-top: 1px solid rgba(255, 255, 255, 0.12); padding: 2.5rem 0; text-align: center; margin-top: 5rem;
  }
  .copyright { margin: 0; font-size: 0.85rem; color: #a3a0a8; letter-spacing: 0.05em; }

  /* メイン画像設定 */
  .program-main-img {
    width: 100%;
    max-height: 450px; 
    object-fit: cover;   
    border-radius: 12px; 
    margin-bottom: 2rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    display: block;
  }

  @media (max-width: 768px) {
    .site-header { padding: 0.5rem 1rem; }
    .nav-menu { display: none; }
    .detailed-container { margin-top: 120px; }
    .card-panel { padding: 1.5rem; }
    .program-header-block h2 { font-size: 1.6rem; }
  }

  /* ===================================================
     ★重要：マークダウンの中身を「クラス名なし」で強力に装飾
     =================================================== */
  
  /* 全体の基本テキスト設定 */
  .markdown-content :global(p) {
    line-height: 1.85; margin-bottom: 1.4rem; color: #dbd7e0; letter-spacing: 0.03em;
  }

  /* ① ゴールド縦線の見出し (h3) */
  .markdown-content :global(h3) {
    font-size: 1.3rem !important;
    color: #fff !important;
    border-left: 4px solid #d4af37 !important;
    padding-left: 12px !important;
    margin: 4rem 0 1.5rem 0 !important;
    letter-spacing: 0.05em !important;
    display: block !important;
  }
  .markdown-content :global(h3:first-of-type) {
    margin-top: 2rem !important;
  }

  /* ② 基本の箇条書き(ul)設定：メリットカード用の元スタイル */
  .markdown-content :global(ul) {
    display: grid !important;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)) !important;
    gap: 1.2rem !important;
    margin: 2rem 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .markdown-content :global(ul li) {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    border-radius: 12px !important;
    padding: 1.2rem 1.5rem 1.2rem 1.8rem !important;
    position: relative !important;
    overflow: hidden !important;
    font-size: 0.95rem !important;
    line-height: 1.6 !important;
    color: #e0dce5 !important;
  }

  .markdown-content :global(ul li::marker) {
    font-size: 0 !important;
    color: transparent !important;
  }

  /* メリットカードの左帯を生成 */
  .markdown-content :global(ul li::before) {
    content: '' !important;
    position: absolute !important;
    top: 0; left: 0; bottom: 0; width: 6px;
  }
  /* メリットの個数分だけカラフルに色付け */
  .markdown-content :global(ul > li:nth-child(1)::before) { background: linear-gradient(to bottom, #ff9966, #ff5e62) !important; }
  .markdown-content :global(ul > li:nth-child(2)::before) { background: linear-gradient(to bottom, #f5af19, #f12711) !important; }
  .markdown-content :global(ul > li:nth-child(3)::before) { background: linear-gradient(to bottom, #00c6ff, #0072ff) !important; }
  .markdown-content :global(ul > li:nth-child(4)::before) { background: linear-gradient(to bottom, #7F00FF, #E100FF) !important; }
  .markdown-content :global(ul > li:nth-child(5)::before) { background: linear-gradient(to bottom, #11998e, #38ef7d) !important; }

  .markdown-content :global(ul li strong) {
    color: #ff8da1 !important;
    font-weight: bold !important;
  }

  /* ③ スケジュール（h4 ＋ 番号付きリスト ol）の装飾 */
  .markdown-content :global(h4) {
    color: #ffb7ff !important;
    font-size: 1.05rem !important;
    margin: 2.5rem 0 0.5rem 0 !important;
    display: inline-block !important;
  }

  .markdown-content :global(ol) {
    background: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 12px !important;
    padding: 1.5rem 1.5rem 1.5rem 2.5rem !important;
    margin: 1rem 0 2rem 0 !important;
    list-style-type: decimal !important;
    display: block !important;
  }

  .markdown-content :global(ol li) {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    margin: 0.8rem 0 !important;
    font-size: 0.95rem !important;
    color: #dbd7e0 !important;
    line-height: 1.6 !important;
    overflow: visible !important;
  }
  .markdown-content :global(ol li::before) { display: none !important; }
  .markdown-content :global(ol li::marker) { font-size: 1rem !important; color: #ffb7ff !important; }


  /* ===================================================
     🎨 持ち物リスト（成功した2列デザインの完全固定・維持）
     =================================================== */
  
  .markdown-content :global(ul:has(ul)) {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: wrap !important;
    gap: 1.5rem !important;
    margin: 2rem 0 3rem 0 !important;
    padding: 0 !important;
  }

  .markdown-content :global(ul:has(ul) > li) {
    flex: 1 1 calc(50% - 0.75rem) !important;
    min-width: 280px !important;
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.06) !important;
    border-radius: 12px !important;
    padding: 1.5rem !important;
    overflow: visible !important;
    margin-bottom: 0 !important;
  }

  .markdown-content :global(ul:has(ul) > li::before) {
    content: '' !important;
    position: absolute !important;
    top: 0; left: 0; bottom: 0; width: 6px;
    display: block !important;
  }
  .markdown-content :global(ul:has(ul) > li:nth-of-type(1)::before) { background: linear-gradient(to bottom, #ff9966, #ff5e62) !important; }
  .markdown-content :global(ul:has(ul) > li:nth-of-type(2)::before) { background: linear-gradient(to bottom, #f5af19, #f12711) !important; }

  .markdown-content :global(ul:has(ul) > li strong) { color: #fff !important; }

  .markdown-content :global(ul:has(ul) ul) {
    display: block !important;
    margin: 1rem 0 0 0 !important;
    padding: 0 !important;
  }

  .markdown-content :global(ul:has(ul) ul li) {
    background: rgba(255, 255, 255, 0.04) !important;
    border: 1px solid rgba(255, 255, 255, 0.06) !important;
    border-radius: 8px !important;
    padding: 0.8rem 1rem 0.8rem 2.2rem !important;
    margin: 0.6rem 0 !important;
    color: #dbd7e0 !important;
    overflow: hidden !important;
  }

  .markdown-content :global(ul:has(ul) ul li::before) {
    content: "" !important;
    position: absolute !important;
    left: 0.8rem !important; top: 0 !important; bottom: 0 !important;
    width: 6px !important; height: auto !important;
    border-radius: 2px !important;
  }
  .markdown-content :global(ul:has(ul) > li:nth-of-type(1) ul li::before) { background: linear-gradient(to bottom, #ff9966, #ff5e62) !important; }
  .markdown-content :global(ul:has(ul) > li:nth-of-type(2) ul li::before) { background: linear-gradient(to bottom, #f5af19, #f12711) !important; }


  /* ===================================================
     🎨 料金セクション（崩れを完全修正・コース別の綺麗なカード囲み）
     =================================================== */

  /* 「◆1回」「◆半年」の行の重なりを防ぎ、見出し風にする設定 */
  .markdown-content :global(p:has(strong:contains("◆"))),
  .markdown-content :global(p:has-text("◆")) {
    margin-top: 2.5rem !important;
    margin-bottom: 0.5rem !important;
    padding: 0 !important;
    position: relative !important;
    z-index: 1 !important;
    font-size: 1.1rem !important;
    font-weight: bold !important;
  }

  /* 料金の金額部分（単一のul/li）のスタイル */
  /* 不要なグリッド化や変な点線枠を完全にリセットし、コース名ごと包むような独立カードにします */
  .markdown-content :global(p + ul:not(:has(ul))) {
    display: block !important;
    grid-template-columns: none !important;
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 12px !important;
    padding: 1.5rem !important;
    margin: 0.5rem 0 2rem 0 !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2) !important;
    overflow: hidden !important;
  }

  /* 料金カード内のli要素（金額テキスト部分） */
  .markdown-content :global(p + ul:not(:has(ul)) li) {
    background: none !important;
    border: none !important;
    padding: 0 0 0 1.5rem !important;
    margin: 0 !important;
    width: 100% !important;
    font-size: 1.05rem !important;
    color: #fff !important;
    overflow: visible !important;
  }

  /* 料金カードの左側に美しく伸びる縦帯（もともとliについていたものを外枠用に再調整） */
  .markdown-content :global(p + ul:not(:has(ul)) li::before) {
    content: '' !important;
    position: absolute !important;
    top: 0 !important; left: 0 !important; bottom: 0 !important;
    width: 6px !important; height: 100% !important;
    border-radius: 12px 0 0 12px !important;
  }

  /* 💡対面開催をご希望の方へ の引用ブロック装飾 */
  .markdown-content :global(blockquote) {
    border-left: 4px solid #ffb7ff !important;
    background: rgba(255, 183, 255, 0.05) !important;
    padding: 1rem 1.5rem !important;
    margin: 2.5rem 0 !important;
    border-radius: 0 8px 8px 0;
  }
  .markdown-content :global(blockquote p) { margin: 0 !important; color: #fff !important; font-size: 0.95rem; }

  /* マークダウン内の画像通常設定 */
  .markdown-content :global(img) {
    width: 100%; height: auto; border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3); margin: 2rem 0;
  }
  /* ウサギの画像 */
  .markdown-content :global(img[alt="クレイワークのイメージ"]) {
    width: 30% !important; max-width: 450px !important; height: auto !important;
    margin: 2rem auto !important; display: block !important;
  }

  @media (max-width: 768px) {
    .markdown-content :global(ul:has(ul) > li) {
      flex: 1 1 100% !important;
    }
  }
</style>