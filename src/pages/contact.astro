---
import bgGalaxy from '../assets/bg-galaxy.avif';
import Layout from '../layouts/Layout.astro'; // プロジェクトのLayoutのパスに合わせて適宜微調整してください
import PageTop from '../components/PageTop.astro';
import * as contactData from '../content/contact.md';
const { frontmatter } = contactData;
---

<Layout title={`${frontmatter.title} | 一樂 迦哩無 - 公式サイト`}>
  <!-- 背景画像 -->
  <div class="bg-layer"></div>

  <!-- メインコンテンツ -->
  <main class="detailed-container">
    <section class="card-panel">
      <div class="program-header-block">
        <p class="catchphrase">{frontmatter.catchphrase}</p>
        <h2>{frontmatter.title}</h2>
      </div>
      
      <div class="card-content detailed-body">
        {frontmatter.image && (
          <img src={frontmatter.image} alt="メインイメージ" class="program-main-img" />
        )}
        <div class="summary-message">
          <p>{frontmatter.summary}</p>
        </div>

        <hr class="divider" />
        <!-- Markdownの本文（特徴、おすすめの人、内容など）を自動展開 -->
        <div class="markdown-content">
          <contactData.Content />
        </div>
        
        <div class="back-home-container">
            <a href="/" class="back-home-link">トップページへ戻る</a>
        </div>
      </div>
    </section>
  </main>

  <PageTop />
</Layout>

<!-- スタイル設定 -->
<style is:global>
  /* ===================================================
     🪐 全体レイアウトとカードパネルの復元
     =================================================== */
  .detailed-container {
    flex: 1;
    max-width: 900px;
    margin: 140px auto 60px auto;
    padding: 0 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }
  
  .card-panel {
    background: rgba(13, 11, 24, 0.85) !important; /* 背景の黒半透明パネルを確実に復活 */
    border: 1px solid rgba(255, 255, 255, 0.08) !important; 
    border-radius: 16px !important;
    padding: 2.5rem !important; 
    backdrop-filter: blur(12px) !important;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6) !important;
    overflow: hidden;
    box-sizing: border-box;
  }
  
  /* 見出し・キャッチコピー */
  .program-header-block h2 { 
    font-size: 2rem !important; 
    margin-top: 0.2rem !important; 
    margin-bottom: 2rem !important; 
    color: #fff !important;
  }
  .catchphrase {
    color: #ffb7ff !important; 
    font-size: 0.95rem !important; 
    font-weight: bold !important; 
    margin: 0 !important; 
    letter-spacing: 0.1em !important;
    white-space: pre-line !important;
  }
  .summary-message p { 
    font-size: 1.1rem !important; 
    line-height: 1.8 !important; 
    color: #fff !important;
    white-space: pre-line !important;
  }
  
  .divider {
    border: 0 !important; 
    height: 1px !important;
    background: linear-gradient(to right, rgba(255,255,255,0), rgba(255,255,255,0.15), rgba(255,255,255,0)) !important;
    margin: 2.5rem 0 !important;
  }

  .program-main-img {
    width: 100% !important;
    max-height: 450px !important; 
    object-fit: cover !important;   
    border-radius: 12px !important; 
    margin-bottom: 2rem !important;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4) !important;
    display: block !important;
  }

  /* 🏡 トップページへ戻るリンク */
  .back-home-container { 
    text-align: center !important; 
    margin-top: 4rem !important; 
  }
  .back-home-link { 
    color: #aaa !important; 
    text-decoration: none !important; 
    font-size: 0.95rem !important; 
    transition: color 0.3s !important;
    border-bottom: none !important; 
    display: inline-block !important;
  }
  .back-home-link:hover { 
    color: #ffb7ff !important; 
  }

  /* ===================================================
     📚 マークダウン本文（markdown-content）の最適化
     =================================================== */
  .markdown-content p {
    line-height: 1.95 !important; 
    margin-bottom: 1.8rem !important; 
    color: #dbd7e0 !important; 
    letter-spacing: 0.04em !important;
    font-size: 1.05rem !important;
  }

  /* 普通のテキストリンクスタイル（ボタン以外のaタグに適用） */
  .markdown-content a:not(.btn-action) {
    color: #a3e2ff !important;
    text-decoration: none !important;
    font-weight: bold !important;
    border-bottom: 1px dashed rgba(163, 226, 255, 0.6) !important;
    transition: all 0.3s ease !important;
  }
  
  .markdown-content a:not(.btn-action):hover {
    color: #ffb7ff !important;
    border-bottom: 1px solid #ffb7ff !important;
    text-shadow: 0 0 8px rgba(255, 183, 255, 0.5) !important;
  }

  /* ===================================================
     ✨ お申し込み・お問い合わせボタン（完全独立設計）
     =================================================== */
  
  /* ボタンコンテナ */
  .markdown-content .action-buttons-container,
  .action-buttons-container {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 1.2rem !important;
    margin: 3.5rem 0 !important;
    width: 100% !important;
  }

  /* ボタン共通ベース */
  .markdown-content .btn-action,
  .btn-action {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    text-align: center !important;
    
    width: 100% !important;
    max-width: 480px !important;            
    min-width: 260px !important;
    
    height: auto !important;                
    min-height: 56px !important;            
    padding: 12px 18px !important;          
    white-space: normal !important;         
    word-break: break-all !important;       
    
    border-radius: 30px !important;
    font-size: 1.05rem !important;
    font-weight: bold !important;
    letter-spacing: 0.05em !important;
    position: relative !important;
    z-index: 1 !important;
    transition: all 0.4s ease !important;
    overflow: hidden !important;
    text-decoration: none !important;
    
    /* 他の干渉をすべて排除 */
    border: none !important;
    border-bottom: 0px solid transparent !important;
    box-shadow: none !important;
    background-image: none !important;
  }

  /* ボタン内の文字 */
  .markdown-content .btn-action span,
  .btn-action span {
    position: relative !important;
    z-index: 5 !important;
    display: block !important;
    line-height: 1.4 !important;            
    border-bottom: 0px solid transparent !important;
    text-decoration: none !important;
    background-image: none !important;
  }

  /* 🔥 お申し込みボタン（ピンク〜オレンジ） */
  .markdown-content .btn-apply,
  .btn-apply {
    background: linear-gradient(135deg, #ff5e62, #ff9966) !important;
    box-shadow: 0 4px 15px rgba(255, 94, 98, 0.4) !important;
  }

  .markdown-content .btn-apply span,
  .btn-apply span {
    color: #fff !important;
  }

  .markdown-content .btn-apply::before,
  .btn-apply::before {
    content: '' !important;                 
    position: absolute !important;
    top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important;
    background: linear-gradient(135deg, #ff9966, #ff5e62) !important;
    opacity: 0 !important;
    z-index: 2 !important;
    transition: opacity 0.4s ease !important;
  }

  .markdown-content .btn-apply:hover,
  .btn-apply:hover {
    transform: translateY(-3px) !important;
    box-shadow: 0 8px 25px rgba(255, 94, 98, 0.6), 0 0 15px rgba(255, 153, 102, 0.4) !important;
    border-bottom: 0px solid transparent !important;
  }
  
  .markdown-content .btn-apply:hover::before,
  .btn-apply:hover::before {
    opacity: 1 !important;
  }

  /* 💬 お問い合わせボタン：パープルネオン調 */
  .markdown-content .btn-contact,
  .btn-contact {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 2px solid #ffb7ff !important;   
    box-shadow: 0 4px 15px rgba(255, 183, 255, 0.1) !important;
  }

  .markdown-content .btn-contact span,
  .btn-contact span {
    color: #ffb7ff !important;              
  }

  .markdown-content .btn-contact:hover,
  .btn-contact:hover {
    transform: translateY(-3px) !important;
    background: rgba(255, 183, 255, 0.15) !important;
    box-shadow: 0 8px 25px rgba(255, 183, 255, 0.4), 0 0 15px rgba(255, 183, 255, 0.2) !important;
    border: 2px solid #ffb7ff !important;
  }

  .markdown-content .btn-contact:hover span,
  .btn-contact:hover span {
    color: #fff !important;                 
    text-shadow: 0 0 5px rgba(255, 255, 255, 0.5) !important;
  }

  .markdown-content .btn-action:visited,
  .btn-action:visited {
    text-decoration: none !important;
  }

  /* ===================================================
     🎨 その他マークダウンコンテンツ装飾（見出し・カード・スケジュール等）
     =================================================== */
  
  /* ゴールド縦線の見出し (h3) */
  .markdown-content h3 {
    font-size: 1.3rem !important;
    color: #fff !important;
    border-left: 4px solid #d4af37 !important;
    padding-left: 12px !important;
    margin: 4rem 0 1.5rem 0 !important;
    letter-spacing: 0.05em !important;
    display: block !important;
  }
  .markdown-content h3:first-of-type {
    margin-top: 2rem !important;
  }

  /* メリットカード */
  .markdown-content ul {
    display: grid !important;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)) !important;
    gap: 1.2rem !important;
    margin: 2rem 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .markdown-content ul li {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    border-radius: 12px !important;
    padding: 1.2rem 1.5rem 1.2rem 1.8rem !important;
    position: relative !important;
    overflow: hidden !important;
    font-size: 0.95rem !important;
    line-height: 1.6 !important;
    color: #e0dce5 !important;
    list-style-type: none !important;
  }

  .markdown-content ul > li::before {
    content: '' !important;
    position: absolute !important;
    top: 0 !important; left: 0 !important; bottom: 0 !important; width: 6px !important;
    height: 100% !important;
  }
  .markdown-content ul > li:nth-child(1)::before { background: linear-gradient(to bottom, #ff9966, #ff5e62) !important; }
  .markdown-content ul > li:nth-child(2)::before { background: linear-gradient(to bottom, #f5af19, #f12711) !important; }
  .markdown-content ul > li:nth-child(3)::before { background: linear-gradient(to bottom, #00c6ff, #0072ff) !important; }
  .markdown-content ul > li:nth-child(4)::before { background: linear-gradient(to bottom, #7F00FF, #E100FF) !important; }
  .markdown-content ul > li:nth-child(5)::before { background: linear-gradient(to bottom, #11998e, #38ef7d) !important; }
  .markdown-content ul > li:nth-child(6)::before { background: linear-gradient(to bottom, #00f2fe, #4facfe) !important; }

  .markdown-content ul li strong {
    color: #ff8da1 !important;
    font-weight: bold !important;
  }

  /* ⏰ スケジュール */
  .markdown-content h4 {
    color: #ffb7ff !important;
    font-size: 1.05rem !important;
    margin: 2.5rem 0 0.5rem 0 !important;
    padding: 0 !important;
    position: relative !important;
    display: block !important;
    z-index: 1 !important;
  }

  .markdown-content ol {
    background: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 12px !important;
    padding: 1.5rem 1.5rem 1.5rem 2.5rem !important;
    margin: 0.5rem 0 2.5rem 0 !important;
    list-style-type: decimal !important;
    display: block !important;
    clear: both !important;
  }

  .markdown-content ol li {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    margin: 0.8rem 0 !important;
    font-size: 0.95rem !important;
    color: #dbd7e0 !important;
    line-height: 1.6 !important;
  }
  .markdown-content ol li::before { display: none !important; content: none !important; }
  .markdown-content ol li::marker { font-size: 1rem !important; color: #ffb7ff !important; }

  /* 🎨 持ち物リスト（2列レイアウト） */
  .markdown-content ul:has(ul) {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: wrap !important;
    justify-content: space-between !important;
    gap: 1.5rem !important;
    margin: 2rem 0 3rem 0 !important;
    padding: 0 !important;
    list-style-type: none !important;
  }

  .markdown-content ul:has(ul) > li {
    flex: 0 1 calc(50% - 0.75rem) !important;
    min-width: 300px !important;
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.06) !important;
    border-radius: 12px !important;
    padding: 1.5rem 2rem 2rem 2rem !important;
    overflow: visible !important;
    list-style-type: none !important;
    display: block !important;
    position: relative !important;
  }
  .markdown-content ul:has(ul) > li::marker { display: none !important; content: none !important; }

  .markdown-content ul:has(ul) > li::before {
    content: '' !important;
    position: absolute !important;
    top: 0 !important; left: 0 !important; bottom: 0 !important; width: 6px !important;
    height: 100% !important;
    background: linear-gradient(to bottom, #ff9966, #ff5e62) !important;
  }
  .markdown-content ul:has(ul) > li:nth-of-type(2)::before { 
    background: linear-gradient(to bottom, #f5af19, #f12711) !important; 
  }

  .markdown-content ul:has(ul) ul {
    display: block !important;
    margin: 0.5rem 0 0 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .markdown-content ul:has(ul) ul li {
    background: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid rgba(255, 255, 255, 0.04) !important;
    border-radius: 8px !important;
    padding: 0.9rem 1.2rem 0.9rem 2.8rem !important;
    margin: 0.6rem 0 !important;
    position: relative !important;
    font-size: 0.95rem !important;
    color: #dbd7e0 !important;
    overflow: visible !important;
    list-style-type: none !important;
    display: block !important;
  }
  .markdown-content ul:has(ul) ul li::marker { display: none !important; content: none !important; }

  .markdown-content ul:has(ul) ul li::before {
    content: '✓' !important;
    position: absolute !important;
    left: 1.2rem !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    font-weight: bold !important;
    font-size: 1.1rem !important;
    background: none !important;
    width: auto !important;
    height: auto !important;
  }
  .markdown-content ul:has(ul) > li:nth-of-type(1) ul li::before { color: #ff8da1 !important; }
  .markdown-content ul:has(ul) > li:nth-of-type(2) ul li::before { color: #d4af37 !important; }

  /* 🎨 料金セクション */
  .markdown-content h4 + ul {
    display: block !important;
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 16px !important;
    padding: 5.5rem 2rem 2rem 2rem !important;
    margin: 0 0 3.5rem 0 !important;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3) !important;
    position: relative !important;
    overflow: hidden !important;
    list-style: none !important;
  }

  .markdown-content h4:has(+ ul) {
    margin-top: 3.5rem !important;
    margin-bottom: -4.5rem !important; 
    position: relative !important;
    z-index: 10 !important;
    padding-left: 2rem !important;
    font-size: 1.15rem !important;
    font-weight: bold !important;
    color: #ffb7ff !important;
    display: block !important;
  }

  .markdown-content h4 + ul::before {
    content: '' !important;
    position: absolute !important;
    top: 0 !important; left: 0 !important; bottom: 0 !important; width: 6px !important;
    z-index: 5 !important;
    height: 100% !important;
  }
  
  .markdown-content h4:has(+ ul) + ul::before {
    background: linear-gradient(to bottom, #ff9966, #ff5e62) !important;
  }
  .markdown-content ul + h4:has(+ ul) + ul::before {
    background: linear-gradient(to bottom, #f5af19, #f12711) !important;
  }

  .markdown-content h4 + ul li {
    background: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid rgba(255, 255, 255, 0.05) !important;
    border-radius: 12px !important;
    padding: 1.5rem 2rem !important;
    margin: 0 !important;
    width: 100% !important;
    font-size: 1.05rem !important;
    color: #fff !important;
    overflow: hidden !important;
    position: relative !important;
    list-style-type: none !important;
    display: block !important;
  }
  .markdown-content h4 + ul li::marker { display: none !important; content: none !important; }

  /* 💡引用ブロック */
  .markdown-content blockquote {
    border-left: 4px solid #ffb7ff !important;
    background: rgba(255, 183, 255, 0.05) !important;
    padding: 1rem 1.5rem !important;
    margin: 2.5rem 0 !important;
    border-radius: 0 8px 8px 0 !important;
  }
  .markdown-content blockquote p { margin: 0 !important; color: #fff !important; font-size: 0.95rem !important; }

  /* 画像通常設定 */
  .markdown-content img {
    width: 100% !important; height: auto !important; border-radius: 12px !important;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3) !important; margin: 2rem 0 !important;
  }
  .markdown-content img[alt="クレイワークのイメージ"] {
    width: 30% !important; max-width: 450px !important; height: auto !important;
    margin: 2rem auto !important; display: block !important;
  }
  .markdown-content img[alt="受講生の声"] {
    width: 70% !important; max-width: 450px !important; height: auto !important;
    margin: 2rem auto !important; display: block !important;
  }

  /* ===================================================
     📱 スマホレスポンシブ
     =================================================== */
  @media (max-width: 768px) {
    .detailed-container { margin-top: 120px; }
    .card-panel { padding: 1.5rem !important; }
    .program-header-block h2 { font-size: 1.6rem !important; }
    
    .markdown-content .btn-action,
    .btn-action {
      padding: 10px 14px !important;        
      max-width: 90% !important;            
    }
    
    .markdown-content .btn-action span,
    .btn-action span {
      font-size: 0.9rem !important;         
      line-height: 1.35 !important;
    }
    .markdown-content ul:has(ul) > li {
      flex: 1 1 100% !important;
    }
  }
</style>

<!-- Astro完全対応版インラインスクリプト -->
<script is:inline>
  function setupFormButtons() {
    const container = document.querySelector('.action-buttons-container');
    if (!container) return;

    const links = container.querySelectorAll('a');
    links.forEach(link => {
      link.setAttribute('target', '_blank');
      link.setAttribute('rel', 'noopener noreferrer');
      
      link.onclick = function(e) {
        e.preventDefault();
        e.stopPropagation();
        const href = this.getAttribute('href');
        if (href) {
          window.open(href, '_blank', 'noopener,noreferrer');
        }
        return false;
      };
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupFormButtons);
  } else {
    setupFormButtons();
  }

  document.addEventListener('astro:page-load', setupFormButtons);
  document.addEventListener('astro:after-swap', setupFormButtons);
</script>