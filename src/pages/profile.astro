---
import bgGalaxy from '../assets/bg-galaxy.avif';
import Header from '../components/Header.astro';
import PageTop from '../components/PageTop.astro';

// ★テキストファイルを読み込む
import * as profileData from '../content/profile.md';
const { frontmatter } = profileData;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>一樂 迦哩無について - 詳細プロフィール | 一樂 迦哩無 - 公式サイト</title>
  </head>
  <body>
    <!-- 背景画像 -->
   <div class="bg-layer"></div>
    
<!-- ヘッダー -->
<Header />

    <!-- メインコンテンツ（中央配置の1カラムコンテナ） -->
    <main class="detailed-container">
      <section class="card-panel">
        <div class="profile-header-block">
          <p class="catchphrase">{frontmatter.catchphrase}</p>
          <h2>{frontmatter.title}</h2>
        </div>
        
        <div class="card-content detailed-story">

{frontmatter.image && (
            <div class="toppage-image-container">
              <img src={frontmatter.image} alt={frontmatter.title} class="toppage-main-image" />
            </div>
          )}

          <div class="intro-message">
            <p class="greeting">{frontmatter.greeting}</p>
            <blockquote>
              {frontmatter.quote}
            </blockquote>
          </div>


            <profileData.Content />

          

          
          <div class="back-home-container">
              <a href="/" class="back-home-link">トップページへ戻る</a>
          </div>

        </div>
      </section>
    </main>

    <!-- フッター -->
    <footer class="site-footer">
      <div class="footer-content">
        <p class="copyright">&copy; 2026 一樂 迦哩無 All Rights Reserved.</p>
      </div>
    </footer>
    <PageTop />
  </body>
</html>


<!-- スタイル設定 -->
<style define:vars={{ bgUrl: `url(${bgGalaxy.src})` }}>
  * { box-sizing: border-box; }
  body { 
    margin: 0; padding: 0;
    background: #0d0b18; color: #f0ecf4; 
    font-family: 'Helvetica Neue', Arial, sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
    display: flex; flex-direction: column;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* 背景アニメーション（これで無事に復活します！） */
  .bg-layer {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background-image: var(--bgUrl); background-size: cover; background-position: center;
    z-index: -2; opacity: 0.7;
    animation: bgMovement 25s ease-in-out infinite alternate;
  }
  @keyframes bgMovement {
    0% { transform: scale(1) rotate(0deg); }
    100% { transform: scale(1.08) rotate(1deg); }
  }

  /* ヘッダー */
  .site-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.5rem 3rem; height: 100px;
    background: rgba(13, 11, 24, 0.6); backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: fixed; top: 0; width: 100%; z-index: 100;
  }
  .site-logo-img { max-height: 80px; width: auto; object-fit: contain; }
  .nav-menu ul { display: flex; list-style: none; gap: 2rem; margin: 0; padding: 0; }
  .nav-menu a { color: #fff; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.3s; }
  .nav-menu a:hover { color: #ffb7ff; text-shadow: 0 0 8px #ffb7ff; }

  /* メインコンテンツコンテナ */
  .detailed-container {
    flex: 1;
    max-width: 900px; 
    margin: 140px auto 60px auto; 
    padding: 0 1.5rem;
    width: 100%;
  }
  
  /* カードパネル設定 */
  .card-panel {
    background: rgba(13, 11, 24, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px;
    padding: 2.5rem; backdrop-filter: blur(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }
  
  /* テキスト装飾 */
  .profile-header-block h2 { font-size: 2rem; margin-top: 0.2rem; margin-bottom: 2rem; }
  .catchphrase {
    color: #ffb7ff; font-size: 0.95rem; font-weight: bold; margin: 0; letter-spacing: 0.1em;
    white-space: pre-line;
  }

  .story-block h3, .skills-block h3 {
    font-size: 1.4rem; color: #ffb7ff; text-shadow: 0 0 8px rgba(255, 183, 255, 0.5);
    margin-top: 2rem; margin-bottom: 1.5rem; letter-spacing: 0.05em;
  }

  .detailed-story p { 
    line-height: 1.85; margin-bottom: 1.4rem; color: #dbd7e0; letter-spacing: 0.03em;
  }
  .intro-message .greeting { font-size: 1.15rem; font-weight: bold; color: #fff; }
  .intro-message blockquote {
    margin: 1.5rem 0; padding-left: 1.2rem; border-left: 3px solid #ffb7ff;
    font-style: italic; color: #fff; font-size: 1.1rem;
    white-space: pre-line;
  }

  .personal-info {
    background: rgba(255, 255, 255, 0.03); padding: 1.2rem;
    border-radius: 8px; margin-top: 2rem; font-size: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .personal-info p { margin: 0.6rem 0; }

  /* スキルグリッド */
  .skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .skills-grid h4 { margin: 0 0 0.8rem 0; font-size: 1.1rem; color: #a3e2ff; }
  .skills-grid ul { margin: 0; padding-left: 1.2rem; font-size: 0.95rem; line-height: 1.7; }
  .skills-grid ul li { margin-bottom: 0.4rem; }
  .sub-info { font-size: 0.9rem; color: #aaa; margin: 0 0 0.8rem 0; }
  
  /* 戻るリンク */
  .back-home-container { text-align: center; margin-top: 4rem; }
  .back-home-link { color: #aaa; text-decoration: none; font-size: 0.95rem; transition: color 0.3s; }
  .back-home-link:hover { color: #ffb7ff; }

  /* フッターの装飾 */
  .site-footer {
    display: block !important; position: relative; z-index: 9999 !important; width: 100vw;
    margin-left: calc(-50vw + 50%); background: #0d0b18 !important;
    border-top: 1px solid rgba(255, 255, 255, 0.12); padding: 2.5rem 0; text-align: center; margin-top: 5rem;
  }
  .copyright { margin: 0; font-size: 0.85rem; color: #a3a0a8; letter-spacing: 0.05em; }
  
  /* レスポンシブ対応 */
  @media (max-width: 768px) {
    .site-header { padding: 0.5rem 1rem; }
    .nav-menu { display: none; }
    .detailed-container { margin-top: 120px; }
    .card-panel { padding: 1.5rem; }
    .profile-header-block h2 { font-size: 1.6rem; }
    .skills-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>

<!-- ✨ Markdownの中身を確実に装飾するためのグローバル指定（ここを分離しました！） -->
<style is:global>
  /* Markdownの「###」を左線付きのネオンラインに */
  .card-panel h3 {
    font-size: 1.35rem !important;
    color: #ffb7ff !important;
    text-shadow: 0 0 10px rgba(255, 183, 255, 0.4) !important;
    border-left: 3px solid #ffb7ff !important;
    padding-left: 0.8rem !important;
    margin-top: 3.5rem !important;
    margin-bottom: 2rem !important;
    letter-spacing: 0.08em !important;
    background: none !important;
  }
  
  /* リスト全体に薄いオーラのような背景グラデーションを敷く */
  .card-panel h4 + ul {
    list-style: none !important;
    padding-left: 0 !important;
    margin: 0.8rem 0 2rem 0 !important;
    background: linear-gradient(to right, rgba(163, 226, 255, 0.03), transparent) !important;
    padding: 1rem 1.2rem !important;
    border-radius: 6px !important;
  }
  
  /* 各リスト項目の設定 */
  .card-panel ul li {
    position: relative !important;
    padding-left: 1.4rem !important;
    margin-bottom: 0.6rem !important;
    color: #dbd7e0 !important;
    font-size: 0.95rem !important;
    background: none !important;
    border: none !important;
  }
  
  /* 行頭の丸ドットを、光る星屑（✦）に */
  .card-panel ul li::before {
    content: "✦" !important;
    color: #a3e2ff !important;
    position: absolute !important;
    left: 0 !important;
    top: -1px !important;
    font-size: 0.9rem !important;
    line-height: 1.4 !important;
    background: none !important;
    width: auto !important;
    height: auto !important;
    text-shadow: 0 0 4px rgba(163, 226, 255, 0.6) !important;
  }

  /* 小見出し（####）のカラーを水色に統一 */
  .card-panel h4 {
    margin-top: 2rem !important;
    margin-bottom: 0.6rem !important;
    font-size: 1.1rem !important;
    color: #a3e2ff !important;
    letter-spacing: 0.05em !important;
  }

  /* 普通の文章テキスト（p）の余白とバランス調整 */
  .card-panel h4 + p {
    line-height: 1.85 !important;
    color: #dbd7e0 !important;
    margin-bottom: 2rem !important;
    letter-spacing: 0.03em !important;
    padding-left: 1.2rem !important;
  }

  /* Markdown内の区切り線（---）の装飾 */
  .card-panel hr {
    border: 0 !important;
    height: 1px !important;
    background: linear-gradient(to right, rgba(255,255,255,0), rgba(255, 183, 255, 0.4), rgba(255,255,255,0)) !important;
    margin: 3.5rem 0 !important;
  }

</style>

<style is:global>
  .toppage-image-container {
    width: 100%;
    margin: 0 auto 2rem auto;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(255, 183, 255, 0.2);
    border: 1px solid rgba(255, 183, 255, 0.3);
  }
  .toppage-main-image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
</style>