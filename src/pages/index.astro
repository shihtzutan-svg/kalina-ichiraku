---
import portrait from '../assets/portrait.avif';
import mascot1 from '../assets/mascot1.avif';
import mascot2 from '../assets/mascot2.avif';
import mascot3 from '../assets/mascot3.avif';
import mascot4 from '../assets/mascot4.avif';
import bgGalaxy from '../assets/bg-galaxy.avif';
import logo from '../assets/logo.avif';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>一樂 迦哩無 - 公式サイト</title>
  </head>
  <body>
    <!-- 背景画像 -->
    <div class="bg-layer"></div>

    <!-- ヘッダー -->
    <header class="site-header">
      <div class="logo-area">
        <a href="/"><img src={logo.src} alt="一樂 迦哩無" class="site-logo-img" /></a>
      </div>
      <nav class="nav-menu">
        <ul>
          <li><a href="/#profile">プロフィール</a></li>
          <li><a href="/#activities">活動内容</a></li>
          <li><a href="/#clay">クレイワーク・プログラム</a></li>
          <li><a href="/#service">ライトワーカー様向けサービス</a></li>
          <li><a href="/#contact">お申し込み・お問い合わせ</a></li>
        </ul>
      </nav>
    </header>

    <!-- ヒーローセクション -->
    <section class="hero-section">
      <div class="floating-container">
        <!-- マスコット -->
        <img src={mascot1.src} alt="Mascot1" class="mascot m1" />
        <img src={mascot2.src} alt="Mascot2" class="mascot m2" />
        
        <!-- ポートレート -->
        <div class="portrait-container">
          <img src={portrait.src} alt="一樂 迦哩無" class="portrait-img" />
        </div>
        
        <img src={mascot3.src} alt="Mascot3" class="mascot m3" />
        <img src={mascot4.src} alt="Mascot4" class="mascot m4" />
      </div>
    </section>

    <!-- メインコンテンツ -->
    <main class="content-grid">
      <!-- トップページ用 プロフィールセクション（要約版） -->
      <section class="card-panel profile-section" id="profile">
        <div class="profile-header-block">
          <p class="catchphrase">魂の声を形にする 創作系スピリチュアルワーカー</p>
          <h2>プロフィール</h2>
        </div>
        
        <div class="card-content intro-message">
          <p class="greeting">こんにちは、一樂 迦哩無（いちらく かりな）です。</p>
          <blockquote>
            「みんなが自分の個性を発揮して、自由に生きてほしい」
          </blockquote>
          <p>
            壮絶な葛藤から「源」との対話、そして奇跡的な負債完済を経て、現在は造形力とスピリチュアル能力を融合させた活動を行っています。
          </p>
          <a href="/profile" class="read-more">一樂 迦哩無について 続きはこちら →</a>
        </div>
      </section>

      <!-- クレイワークセクション -->
      <section class="card-panel" id="clay">
        <h2>クレイワーク・プログラム</h2>
        <div class="card-content">
          <p>ここにクレイワークの詳細が入ります。</p>
        </div>
      </section>

      <!-- サービスセクション -->
      <section class="card-panel" id="service">
        <h2>ライトワーカー様向けサービス</h2>
        <div class="card-content">
          <p>ここにサポートサービスの詳細が入ります。</p>
        </div>
      </section>
    </main>

    <!-- ★フッター（完全にmainの外側に配置） -->
    <footer class="site-footer">
      <div class="footer-content">
        <p class="copyright">&copy; 2026 一樂 迦哩無 All Rights Reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style define:vars={{ bgUrl: `url(${bgGalaxy.src})` }}>
  * { box-sizing: border-box; }
body { 
    margin: 0; 
    padding: 0;
    background: #0d0b18; 
    color: #f0ecf4; 
    font-family: 'Helvetica Neue', Arial, sans-serif;
    overflow-x: hidden;
    
    /* ★ここを書き換え・追記します */
    min-height: 100vh;           /* 常に画面の高さ100%分を最低限キープ */
    display: flex;               /* Flexboxレイアウトを開始 */
    flex-direction: column;      /* 中身を上から下へ縦並びにする */
    
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* 背景アニメーション */
  .bg-layer {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background-image: var(--bgUrl); background-size: cover; background-position: center;
    z-index: -2;
    opacity: 0.7;
    animation: bgMovement 25s ease-in-out infinite alternate;
  }
  @keyframes bgMovement {
    0% { transform: scale(1) rotate(0deg); }
    100% { transform: scale(1.08) rotate(1deg); }
  }

  /* ヘッダー */
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 3rem;
    height: 100px;
    background: rgba(13, 11, 24, 0.6);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    z-index: 10;
  }
  .logo-area { display: flex; align-items: center; height: 100%; }
  .site-logo-img { 
    max-height: 80px; 
    width: auto; 
    object-fit: contain; 
    display: block;
  }
  
  .nav-menu ul { display: flex; list-style: none; gap: 2rem; margin: 0; padding: 0; }
  .nav-menu a { color: #fff; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.3s; }
  .nav-menu a:hover { color: #ffb7ff; text-shadow: 0 0 8px #ffb7ff; }

  /* ヒーローエリア */
  .hero-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100px 0 0 0; 
  }
  .floating-container {
    position: relative;
    width: 100%;
    max-width: 1200px;
    height: 600px;
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }
  
  /* パソコン用ポートレートコンテナ */
  .portrait-container {
    width: 600px; 
    height: 600px; 
    overflow: hidden;
    z-index: 2;
    display: flex;
    align-items: flex-end;
  }
  .portrait-img { 
    width: 100%; 
    height: auto; 
    display: block;
  }

  /* マスコット */
  .mascot { width: 220px; height: auto; position: absolute; z-index: 3; }
  
  /* PC向けマスコット位置 */
  .m1 { top: 2%; left: 16%; animation: float1 5s ease-in-out infinite; }
  .m2 { bottom: 15%; left: 14%; animation: float2 6s ease-in-out infinite; }
  .m3 { top: 3%; right: 16%; animation: float1 5.5s ease-in-out infinite; animation-delay: 1s; }
  .m4 { bottom: 18%; right: 14%; animation: float2 4.5s ease-in-out infinite; animation-delay: 0.5s; }

  @keyframes float1 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(2deg); }
  }
  @keyframes float2 {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(15px) rotate(-2deg); }
  }

  /* 下部コンテンツエリア */
/* 下部コンテンツエリア（content-grid）のところに1行追加 */
  .content-grid {
    flex: 1; /* ★これを追記！余った縦方向のスペースをこのエリアが自動で全部埋めます */
    
    display: grid;
    grid-template-columns: 1fr 1.3fr 1fr;
    gap: 2rem;
    padding: 3rem 4rem;
    background: linear-gradient(to bottom, rgba(13, 11, 24, 0.7) 0%, rgba(13, 11, 24, 0.95) 100%);
    min-height: 400px;
    position: relative;
    z-index: 5;
    margin-top: 0;
  }
  
  .card-panel {
    background: rgba(13, 11, 24, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2rem;
    backdrop-filter: blur(8px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }
  .card-panel h2 { 
    font-size: 1.25rem; 
    border-bottom: 2px solid rgba(255, 255, 255, 0.08); 
    padding-bottom: 0.75rem; 
    margin-top: 0;
  }
  .card-content { 
    color: #dbd7e0; 
    font-size: 0.95rem; 
    line-height: 1.75; 
    letter-spacing: 0.03em;
  }

  /* 続きはこちらリンクの装飾 */
  .read-more {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.8rem 1.2rem;
    background: linear-gradient(135deg, #ffb7ff 0%, #a3e2ff 100%);
    color: #0d0b18 !important;
    text-decoration: none;
    font-weight: bold;
    border-radius: 50px;
    font-size: 0.95rem;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 15px rgba(255, 183, 255, 0.3);
  }
  .read-more:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 183, 255, 0.5);
  }

  .catchphrase {
    color: #ffb7ff;
    font-size: 0.95rem;
    font-weight: bold;
    margin: 0 0 0.2rem 0;
    letter-spacing: 0.1em;
  }
  .intro-message .greeting {
    font-size: 1.1rem;
    font-weight: bold;
    color: #fff;
  }
  .intro-message blockquote {
    margin: 1rem 0;
    padding-left: 1rem;
    border-left: 3px solid #ffb7ff;
    font-style: italic;
    color: #fff;
    font-size: 1.05rem;
  }

  /* フッターの装飾（最終解決版） */
  .site-footer {
    display: block !important;
    position: relative;
    z-index: 9999 !important;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    background: #0d0b18 !important;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding: 2.5rem 0;
    text-align: center;
    margin-top: 5rem;
  }
  .copyright {
    margin: 0;
    font-size: 0.85rem;
    color: #a3a0a8;
    letter-spacing: 0.05em;
  }

  /* タブレット対応 */
  @media (max-width: 1100px) {
    .hero-section { padding: 40px 0 0 0; }
    .content-grid { grid-template-columns: 1fr; padding: 2rem; }
    .site-header { padding: 0.5rem 1.5rem; }
    .nav-menu ul { gap: 1.2rem; }
    .floating-container { height: 460px; }
    .portrait-container { width: 460px; height: 460px; }
    .mascot { width: 160px; }
    .m1 { left: 8%; top: 15%; } .m2 { left: 5%; bottom: 2%; } 
    .m3 { right: 8%; top: 17%; } .m4 { right: 5%; bottom: 4%; }
  }

  /* スマートフォン対応（768px以下） */
  @media (max-width: 768px) {
    .site-header { flex-direction: column; height: auto; padding: 1rem 1rem 0.5rem 1rem; width: 100%; }
    .nav-menu ul { flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin-top: 0.8rem; }
    
    .hero-section { padding: 0; width: 100%; }
    .floating-container { height: 340px; width: 100%; }
    
    .portrait-container { 
      width: 300px; 
      height: 340px; 
    }
    
    .mascot { width: 110px; }
    .m1 { left: 6%; top: 3%; }     
    .m2 { left: 6%; bottom: 8%; }   
    .m3 { right: 6%; top: 5%; }    
    .m4 { right: 6%; bottom: 10%; } 
  }
</style>