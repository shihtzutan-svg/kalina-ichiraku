---
// src/components/Header.astro
import logo from '../assets/logo.avif';
const isProd = import.meta.env.PROD;
---
{isProd && (
  <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="あなたのID"></script>
)}

<header class="site-header">
  <div class="header-inner">
    <div class="logo-area">
      <a href="/"><img src={logo.src} alt="一樂 迦哩無" class="site-logo-img" /></a>
    </div>

    <button class="menu-trigger" aria-label="メニューを開く">
      <span></span>
      <span></span>
      <span></span>
    </button>


    <nav class="nav-menu">
      <ul>
        <li><a href="/">TOP</a></li>
        <li><a href="/profile">プロフィール</a></li>
        <li><a href="/kana-l">Kana-L（カナエル）</a></li>
        <li><a href="/claywork">クレイワーク・プログラム</a></li>
        <li><a href="/service">ライトワーカー様向けサービス</a></li>
        <li><a href="/spiritual-town">スピリチュアルタウン</a></li>
        <li><a href="/news">お知らせ</a></li>
        <li><a href="/contact">お申し込み・お問い合わせ</a></li>
        <li><a href="https://instagram.com/kalina_ichiraku" target="_blank" rel="noopener noreferrer" class="instagram-nav-link" aria-label="Instagram">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-instagram">
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    </svg>
  </a></li>
<li><a href="https://lin.ee/QDK9CmS" target="_blank" rel="noopener noreferrer" class="sns-nav-link line-link" aria-label="LINE">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="21" height="21" fill="currentColor">
    <!-- LINE公式のトーク吹き出しの形状 -->
    <path d="M24 10.3c0-5.7-5.4-10.3-12-10.3S0 4.6 0 10.3c0 5.1 4.3 9.4 10.1 10.1l-.6 2.8c0 .2.1.4.3.5.1 0 .2 0 .2-.1l3.3-3.1c4.5-1.1 10.7-5.2 10.7-10.2z" />
    <!-- 吹き出しの中に配置する超軽量・極太の「LINE」テキスト -->
    <text x="12" y="13.5" font-family="'Helvetica Neue', Arial, sans-serif" font-weight="900" font-size="5.2" fill="#0d0b18" text-anchor="middle" letter-spacing="-0.1">LINE</text>
  </svg>
</a></li>
      </ul>
    </nav>
  </div>
</header>

<!-- 💡 is:inline をつけることで、ブラウザに直接「絶対に動かしなさい」と命令します -->
<script is:inline>
  // ページが完全に読み込まれたら実行
  document.addEventListener('DOMContentLoaded', () => {
    const trigger = document.querySelector('.menu-trigger');
    const menu = document.querySelector('.nav-menu');
    const menuLinks = document.querySelectorAll('.nav-menu a');

    if (trigger && menu) {
      // ボタンをクリックしたとき
      trigger.addEventListener('click', (e) => {
        e.stopPropagation(); // クリックイベントが外に漏れるのを防ぐ
        trigger.classList.toggle('active');
        menu.classList.toggle('open');
      });

      // メニュー内のリンクをクリックしたとき（閉じる）
      menuLinks.forEach(link => {
        link.addEventListener('click', () => {
          trigger.classList.remove('active');
          menu.classList.remove('open');
        });
      });
    }
  });
</script>

<style>
  /* --- PC・共通デザイン --- */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100px;
    background: rgba(13, 11, 24, 0.6);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 100;
    /* 💡左右の端にピタッとくっつきすぎないよう、適度な余白だけ持たせる */
    padding: 0 4rem; 
    box-sizing: border-box;
  }

  .header-inner {
    /* 💡max-widthの制限をなくすことで、ロゴは左端、メニューは右端へ完全に離れます！ */
    max-width: 100%; 
    width: 100%;
    height: 100%;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo-area {
    flex-shrink: 0;
  }
  .site-logo-img {
    max-height: 80px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  .nav-menu {
    flex-shrink: 1;
  }
  .nav-menu ul {
    display: flex;
    list-style: none;
    gap: 2rem; /* 左右に広く離れるので、メニュー間の隙間も少し広げてゆったりさせます */
    margin: 0;
    padding: 0;
  }
  .nav-menu a {
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem; /* 端に寄るため、少し文字を大きくしても大丈夫です */
    font-weight: 500;
    white-space: nowrap;
    transition: color 0.3s;
  }
  .nav-menu a:hover {
    color: #ffb7ff;
    text-shadow: 0 0 8px #ffb7ff;
  }
  .menu-trigger {
    display: none;
  }

  /* --- スマートフォン対応（768px以下） --- */
  @media (max-width: 768px) {
    .site-header {
      height: 80px;
      padding: 0 1.5rem !important;
    }
    .header-inner {
      max-width: 100%;
    }
    .site-logo-img {
      max-height: 55px;
    }
    .menu-trigger {
      display: flex !important;
      flex-direction: column;
      justify-content: space-between;
      width: 30px;
      height: 22px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      z-index: 200;
    }
    .menu-trigger span {
      width: 100%;
      height: 2px;
      background-color: #fff;
      border-radius: 2px;
      transition: all 0.4s;
    }
    .menu-trigger.active span:nth-child(1) {
      transform: translateY(10px) rotate(-45deg);
      background-color: #ffb7ff;
    }
    .menu-trigger.active span:nth-child(2) {
      opacity: 0;
    }
    .menu-trigger.active span:nth-child(3) {
      transform: translateY(-10px) rotate(45deg);
      background-color: #ffb7ff;
    }
    .nav-menu {
      position: fixed;
      top: -100vh;
      left: 0;
      width: 100%;
      height: 100vh;
      background: rgba(13, 11, 24, 0.95);
      backdrop-filter: blur(20px);
      transition: top 0.4s ease-in-out;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 150;
    }
    .nav-menu.open {
      top: 0;
    }
    .nav-menu ul {
      flex-direction: column;
      align-items: center;
      gap: 2rem !important;
    }
    .nav-menu a {
      font-size: 1.2rem;
      padding: 0.5rem 1rem;
    }
  }


  /* 🌐 SNSリンク全体の共通ルール */
.sns-nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #dbd7e0;
    margin-left: 0.1rem;       /* 💡 アイコン同士の間隔を狭く */
    transition: color 0.2s, filter 0.2s;
    vertical-align: middle;
  }
  
  /* 📸 Instagram：ホバー時にブランドカラーのネオンピンクに光る */
  .instagram-link:hover {
    color: #ffb7ff;
    filter: drop-shadow(0 0 8px rgba(255, 183, 255, 0.6));
  }

  /* 🟢 LINE：ホバー時にLINE公式のネオンクリーンに光る */
  .line-link:hover {
    color: #06C755;
    filter: drop-shadow(0 0 8px rgba(6, 199, 85, 0.6));
  }

  /* LINEアイコンの中の文字は、ホバーしても背景色の「暗い紫」を維持して透過のように見せます */
  .line-link svg text {
    fill: #0d0b18;
    transition: fill 0.2s;
  }

  .sns-nav-link.instagram-link {
    margin-left: 1.0rem;       /* メニューからの独立感を持たせる適切な余白 */
  }

  /* 📱 スマホなど画面が狭いとき、SNSボタンが折り返されて重ならないよう調整 */
  @media (max-width: 768px) {
    .sns-nav-link {
      margin-left: 0rem;
      padding: 0.5rem 0;
    }
  }
</style>