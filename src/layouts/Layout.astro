---
import bgGalaxy from '../assets/bg-galaxy.avif';
import Header from '../components/Header.astro';
import PageTop from '../components/PageTop.astro';

// 各ページから受け取るプロパティ（Props）の定義
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <!-- 背景画像 -->
    <div class="bg-layer"></div>

    <!-- ヘッダー -->
    <Header />

    <!-- 💡 ここに各ページ（indexやclaywork）の個別コンテンツが挿入されます -->
    <slot />

    <!-- フッター（共通化して1箇所に集約！） -->
    <footer class="site-footer">
      <div class="footer-content">
        <div class="footer-links">
          <a href="/privacy">プライバシーポリシー</a>
          <span class="footer-separator">|</span>
          <a href="/tokushouho">特定商取引法に基づく表記</a>
        </div>
        <p class="copyright">&copy; 2026 一樂 迦哩無 All Rights Reserved.</p>
      </div>
    </footer>

    <!-- ページトップへ戻るボタン -->
    <PageTop />

    <!-- 金色の粉を描画するための透明なキャンバスを画面全体に固定配置 -->
    <canvas id="gold-dust-canvas"></canvas>
  </body>
</html>

<!-- 金色の粉を描画するスクリプト（共通レイアウトに集約！） -->
<script>
  const canvas = document.getElementById('gold-dust-canvas') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');

  if (canvas && ctx) {
    const resizeCanvas = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    class Particle {
      x: number;
      y: number;
      size: number;
      speedY: number;
      speedX: number;
      opacity: number;
      fadeSpeed: number;
      angle: number;
      spin: number;

      constructor() {
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * -canvas.height;
        this.size = Math.random() * 2.2 + 0.8;
        this.speedY = Math.random() * 0.8 + 0.4;
        this.speedX = Math.random() * 0.4 - 0.2;
        this.opacity = Math.random() * 0.6 + 0.4;
        this.fadeSpeed = Math.random() * 0.015 + 0.005;
        this.angle = Math.random() * 360;
        this.spin = Math.random() * 0.02 - 0.01;
      }

      update() {
        this.y += this.speedY;
        this.angle += this.spin;
        this.x += this.speedX + Math.sin(this.angle) * 0.2;

        if (this.y > canvas.height) {
          this.y = -20;
          this.x = Math.random() * canvas.width;
          this.opacity = Math.random() * 0.6 + 0.4;
        }
      }

      draw() {
        if (!ctx) return;
        ctx.beginPath();
        const gradient = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size);
        gradient.addColorStop(0, `rgba(255, 245, 200, ${this.opacity})`);
        gradient.addColorStop(0.4, `rgba(218, 165, 32, ${this.opacity * 0.8})`);
        gradient.addColorStop(1, 'rgba(218, 165, 32, 0)');
        
        ctx.fillStyle = gradient;
        ctx.arc(this.x, this.y, this.size * 2, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    const particleCount = 120;
    const particles: Particle[] = [];

    for (let i = 0; i < particleCount; i++) {
      particles.push(new Particle());
    }

    const animate = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach(particle => {
        particle.update();
        particle.draw();
      });
      requestAnimationFrame(animate);
    };

    animate();
  }
</script>

<!-- ① 背景画像変数用のグローバル適用 -->
<style define:vars={{ bgUrl: `url(${bgGalaxy.src})` }}>
  /* 背景アニメーション */
  .bg-layer {
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%;
    background-image: var(--bgUrl); 
    background-size: cover; 
    background-position: center;
    z-index: -2;
    opacity: 0.7;
    animation: bgMovement 25s ease-in-out infinite alternate;
  }
  @keyframes bgMovement {
    0% { transform: scale(1) rotate(0deg); }
    100% { transform: scale(1.08) rotate(1deg); }
  }
</style>

<!-- ② ベース・共通コンポーネント用のグローバルスタイル -->
<style is:global>
  * { box-sizing: border-box; }
  
  body { 
    margin: 0; 
    padding: 0;
    background: #0d0b18; 
    color: #f0ecf4; 
    font-family: 'Helvetica Neue', Arial, sans-serif;
    overflow-x: hidden;
    min-height: 100vh;           
    display: flex;                
    flex-direction: column;      
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* 金色の粉キャンバス */
  #gold-dust-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none; /* クリックを透過させる */
    z-index: 1;           /* 文字の裏側に回り込むように調整 */
  }

  /* ★フッター */
  .site-footer {
    display: block !important; 
    position: relative; 
    z-index: 9999 !important; 
    width: 100vw;
    margin-left: calc(-50vw + 50%); 
    background: #0d0b18 !important;
    border-top: 1px solid rgba(255, 255, 255, 0.12); 
    padding: 2.5rem 0; 
    text-align: center; 
    margin-top: 5rem;
  }
  
  .footer-links {
    margin-bottom: 1rem;
    font-size: 0.85rem;
  }

  .footer-links a {
    color: #a3e2ff; 
    text-decoration: none;
    transition: color 0.3s, text-shadow 0.3s;
    font-weight: 500;
  }

  .footer-links a:hover {
    color: #ffb7ff;
    text-shadow: 0 0 8px #ffb7ff;
  }

  .footer-separator {
    color: rgba(255, 255, 255, 0.2);
    margin: 0 1rem;
  }

  .copyright { 
    margin: 0; 
    font-size: 0.85rem; 
    color: #a3a0a8; 
    letter-spacing: 0.05em; 
  }
</style>